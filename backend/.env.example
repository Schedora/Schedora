# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie
DRIVE_DISK=fs
MAIL_MAILER=smtp
MAIL_FROM_NAME=Your name
MAIL_FROM_ADDRESS=app@yourdomain.com
SMTP_HOST=localhost
SMTP_PORT=1025

#Rate Limiting
echo "LIMITER_STORE=database" >> .env.example